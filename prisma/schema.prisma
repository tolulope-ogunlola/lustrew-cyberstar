// Lustrew CyberStar — data model (first vertical slice).
// Local dev runs on SQLite (zero-setup). SQLite has no native enums, array columns, Json, or
// @db.Text, so enum-like fields are plain strings (values validated in src/lib/validation.ts and
// the string unions in src/lib/types.ts), `frameworks` is a JSON-encoded string, and `metadata`
// is a JSON string. For production Postgres, swap provider to "postgresql" and these map cleanly.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Tenancy & identity
// ---------------------------------------------------------------------------

model Organization {
  id           String   @id @default(cuid())
  name         String
  plan         String   @default("FREE") // FREE | PRO | MSP | ENTERPRISE
  billingEmail String   @default("")
  createdAt    DateTime @default(now())

  users        User[]
  systems      System[]
  policies     Policy[]
  integrations Integration[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String // ADMIN | ATO_SME | ISSO | VULN_ANALYST | SYSTEM_OWNER | EXECUTIVE
  isActive     Boolean  @default(true)
  mustChangePassword Boolean @default(false)
  mfaEnabled   Boolean  @default(false)
  mfaSecret    String? // base32 TOTP secret (set during enrollment)
  passwordResetTokenHash String?
  passwordResetExpires   DateTime?
  createdAt    DateTime @default(now())

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  ownedSystems     System[]                @relation("SystemOwner")
  ownedControls    ControlImplementation[] @relation("ControlOwner")
  ownedRmfSteps    RmfStep[]               @relation("RmfStepOwner")
  ownedPoams       Poam[]                  @relation("PoamOwner")
  ownedRisks       Risk[]                  @relation("RiskOwner")
  uploadedEvidence Evidence[]              @relation("EvidenceUploader")
  signedAuthorizations AuthorizationDecision[] @relation("AuthorizationSigner")
  evidenceRequests EvidenceRequest[]      @relation("EvidenceRequester")
  auditEvents      AuditEvent[]

  @@index([orgId])
}

// ---------------------------------------------------------------------------
// Systems
// ---------------------------------------------------------------------------

model System {
  id           String   @id @default(cuid())
  name         String
  description  String   @default("")
  fipsCategory String   @default("MODERATE") // LOW | MODERATE | HIGH
  frameworks   String   @default("[]") // JSON-encoded string[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orgId   String
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ownerId String?
  owner   User?        @relation("SystemOwner", fields: [ownerId], references: [id])

  implementations ControlImplementation[]
  rmfSteps        RmfStep[]
  evidence        Evidence[]
  poams           Poam[]
  vulnerabilities Vulnerability[]
  scanImports     ScanImport[]
  risks           Risk[]
  stigFindings    StigFinding[]
  ppsmEntries     PpsmEntry[]
  metricSnapshots MetricSnapshot[]
  assessments     Assessment[]
  authorizations  AuthorizationDecision[]
  assets          Asset[]
  evidenceRequests EvidenceRequest[]

  @@index([orgId])
}

// ---------------------------------------------------------------------------
// NIST 800-53 control catalog (global) + per-system implementation
// ---------------------------------------------------------------------------

model Control {
  id        String @id @default(cuid())
  controlId String @unique // e.g. "AC-2" (800-53) or "3.1.1" (800-171)
  family    String // e.g. "AC" or "3.1"
  title     String
  text      String
  baseline  String @default("MODERATE") // LOW | MODERATE | HIGH
  framework String @default("NIST_800_53") // NIST_800_53 | NIST_800_171

  implementations ControlImplementation[]

  @@index([family])
}

model ControlImplementation {
  id           String   @id @default(cuid())
  scoping      String   @default("APPLICABLE") // APPLICABLE | NOT_APPLICABLE | INHERITED | HYBRID | COMPENSATING
  status       String   @default("NOT_IMPLEMENTED") // NOT_IMPLEMENTED | PLANNED | PARTIALLY_IMPLEMENTED | IMPLEMENTED | RISK_ACCEPTED
  narrative    String   @default("")
  providerName String   @default("") // common control provider when scoping is INHERITED/HYBRID (e.g. "AWS GovCloud")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  systemId  String
  system    System  @relation(fields: [systemId], references: [id], onDelete: Cascade)
  controlId String
  control   Control @relation(fields: [controlId], references: [id], onDelete: Cascade)
  ownerId   String?
  owner     User?   @relation("ControlOwner", fields: [ownerId], references: [id])

  evidenceLinks EvidenceLink[]
  poams         Poam[]

  @@unique([systemId, controlId])
  @@index([systemId])
}

// ---------------------------------------------------------------------------
// Evidence vault (many-to-many with control implementations)
// ---------------------------------------------------------------------------

model Evidence {
  id          String   @id @default(cuid())
  title       String
  type        String   @default("Document") // Screenshot | Policy | Scan | Config | Document ...
  url         String   @default("") // external link reference (when not an uploaded file)
  note        String   @default("")
  // Uploaded-file metadata (null when evidence is a link only).
  fileRef     String? // opaque storage key, e.g. "local:org/ev/uuid.pdf"
  fileName    String?
  fileSize    Int?
  contentType String?
  createdAt   DateTime @default(now())

  systemId     String
  system       System @relation(fields: [systemId], references: [id], onDelete: Cascade)
  uploadedById String?
  uploadedBy   User?  @relation("EvidenceUploader", fields: [uploadedById], references: [id])

  links EvidenceLink[]

  @@index([systemId])
}

model EvidenceLink {
  id String @id @default(cuid())

  evidenceId       String
  evidence         Evidence              @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  implementationId String
  implementation   ControlImplementation @relation(fields: [implementationId], references: [id], onDelete: Cascade)

  @@unique([evidenceId, implementationId])
}

// ---------------------------------------------------------------------------
// RMF lifecycle
// ---------------------------------------------------------------------------

model RmfStep {
  id      String    @id @default(cuid())
  step    String // PREPARE | CATEGORIZE | SELECT | IMPLEMENT | ASSESS | AUTHORIZE | MONITOR
  status  String    @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | BLOCKED | COMPLETE
  dueDate DateTime?
  notes   String    @default("")

  systemId String
  system   System  @relation(fields: [systemId], references: [id], onDelete: Cascade)
  ownerId  String?
  owner    User?   @relation("RmfStepOwner", fields: [ownerId], references: [id])

  @@unique([systemId, step])
  @@index([systemId])
}

// ---------------------------------------------------------------------------
// POA&M
// ---------------------------------------------------------------------------

model Poam {
  id                  String    @id @default(cuid())
  poamNumber          String // human-facing id, e.g. "POAM-0007"
  weaknessTitle       String
  weaknessDescription String    @default("")
  source              String    @default("Manual") // Manual | ControlAssessment | Vulnerability | STIG
  severity            String    @default("MODERATE") // INFO | LOW | MODERATE | HIGH | CRITICAL
  riskRating          String    @default("MODERATE")
  cvss                Float?
  status              String    @default("OPEN") // OPEN | IN_PROGRESS | PENDING_REVIEW | COMPLETED | RISK_ACCEPTED | CLOSED
  remediationPlan     String    @default("")
  residualRisk        String    @default("")
  scheduledCompletion DateTime?
  actualCompletion    DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  systemId         String
  system           System                 @relation(fields: [systemId], references: [id], onDelete: Cascade)
  ownerId          String?
  owner            User?                  @relation("PoamOwner", fields: [ownerId], references: [id])
  implementationId String?
  implementation   ControlImplementation? @relation(fields: [implementationId], references: [id])

  milestones    PoamMilestone[]
  statusHistory PoamStatusHistory[]

  @@index([systemId])
}

model PoamMilestone {
  id          String    @id @default(cuid())
  description String
  dueDate     DateTime?
  done        Boolean   @default(false)

  poamId String
  poam   Poam   @relation(fields: [poamId], references: [id], onDelete: Cascade)
}

// Append-only: rows are never updated or deleted.
model PoamStatusHistory {
  id        String   @id @default(cuid())
  status    String
  note      String   @default("")
  changedBy String? // user id
  createdAt DateTime @default(now())

  poamId String
  poam   Poam   @relation(fields: [poamId], references: [id], onDelete: Cascade)

  @@index([poamId])
}

// ---------------------------------------------------------------------------
// Vulnerabilities (scan ingestion)
// ---------------------------------------------------------------------------

model Vulnerability {
  id             String   @id @default(cuid())
  dedupeKey      String // sha1 of pluginId|host|port|cve — recurring findings collapse to one row
  pluginId       String?
  cve            String?
  title          String
  description    String   @default("")
  solution       String   @default("")
  severity       String   @default("MEDIUM") // INFO | LOW | MEDIUM | HIGH | CRITICAL
  cvss           Float?
  host           String?
  port           String?
  source         String   @default("CSV") // Nessus | ACAS | CSV | Manual
  state          String   @default("OPEN") // OPEN | REMEDIATED | RISK_ACCEPTED | FALSE_POSITIVE
  priority       String   @default("MEDIUM") // IMMEDIATE | HIGH | MEDIUM | LOW
  priorityScore  Int      @default(0)
  recommendation String   @default("")
  mappedControl  String? // NIST control id, e.g. "SI-2"
  poamId         String? // set when converted to a POA&M
  firstSeen      DateTime @default(now())
  lastSeen       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@unique([systemId, dedupeKey])
  @@index([systemId])
}

model ScanImport {
  id           String   @id @default(cuid())
  fileName     String
  source       String
  total        Int      @default(0)
  created      Int      @default(0)
  updated      Int      @default(0)
  importedById String?
  createdAt    DateTime @default(now())

  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@index([systemId])
}

// ---------------------------------------------------------------------------
// Risk register
// ---------------------------------------------------------------------------

model Risk {
  id          String @id @default(cuid())
  riskNumber  String // "RISK-0001"
  title       String
  description String @default("")
  threat      String @default("")
  vulnerabilityNarrative String @default("") // free-text weakness (distinct from a linked scan finding)

  // Likelihood/impact on a 1..5 scale: VERY_LOW | LOW | MODERATE | HIGH | VERY_HIGH
  likelihood         String @default("MODERATE")
  impact             String @default("MODERATE")
  residualLikelihood String @default("MODERATE")
  residualImpact     String @default("MODERATE")

  status            String    @default("OPEN") // OPEN | MITIGATING | ACCEPTED | CLOSED
  mitigationPlan    String    @default("")
  acceptanceDecision String   @default("")
  approvalAuthority String    @default("")
  targetDate        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Cross-links stored as ids/strings (resolved at the API boundary) to keep the model light.
  relatedControl  String? // NIST control id, e.g. "RA-3"
  relatedPoamId   String?
  relatedVulnId   String?

  systemId String
  system   System  @relation(fields: [systemId], references: [id], onDelete: Cascade)
  ownerId  String?
  owner    User?   @relation("RiskOwner", fields: [ownerId], references: [id])

  @@index([systemId])
}

// ---------------------------------------------------------------------------
// STIG checklist findings (.ckl import)
// ---------------------------------------------------------------------------

model StigFinding {
  id             String   @id @default(cuid())
  dedupeKey      String
  vulnNum        String // V-XXXXX
  ruleId         String?
  ruleTitle      String
  groupTitle     String   @default("")
  severity       String   @default("CAT_II") // CAT_I | CAT_II | CAT_III
  status         String   @default("NOT_REVIEWED") // OPEN | NOT_A_FINDING | NOT_APPLICABLE | NOT_REVIEWED
  findingDetails String   @default("")
  comments       String   @default("")
  cci            String   @default("")
  host           String?
  stigName       String   @default("")
  source         String   @default("CKL")
  mappedControl  String?
  poamId         String?
  firstSeen      DateTime @default(now())
  lastSeen       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@unique([systemId, dedupeKey])
  @@index([systemId])
}

// ---------------------------------------------------------------------------
// PPSM — Ports, Protocols, and Services Management
// ---------------------------------------------------------------------------

model PpsmEntry {
  id                String   @id @default(cuid())
  port              String
  protocol          String   @default("TCP") // TCP | UDP | ICMP | OTHER
  service           String
  direction         String   @default("INBOUND") // INBOUND | OUTBOUND
  source            String   @default("")
  destination       String   @default("")
  justification     String   @default("")
  status            String   @default("PENDING") // APPROVED | PENDING | DENIED
  associatedControl String? // e.g. SC-7
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@index([systemId])
}

// ---------------------------------------------------------------------------
// Policies & governance
// ---------------------------------------------------------------------------

model Policy {
  id         String    @id @default(cuid())
  title      String
  framework  String    @default("NIST_RMF")
  version    String    @default("1.0")
  status     String    @default("DRAFT") // DRAFT | UNDER_REVIEW | APPROVED | EXPIRED
  body       String    @default("")
  url        String    @default("")
  ownerId    String?
  reviewDate DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  acks PolicyAck[]

  @@index([orgId])
}

model PolicyAck {
  id             String   @id @default(cuid())
  userId         String
  userName       String   @default("")
  acknowledgedAt DateTime @default(now())

  policyId String
  policy   Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([policyId, userId])
}

// ---------------------------------------------------------------------------
// Metric snapshots (daily posture history for trend charts)
// ---------------------------------------------------------------------------

model MetricSnapshot {
  id                      String   @id @default(cuid())
  orgId                   String
  day                     String // YYYY-MM-DD (one row per system per day)
  readinessScore          Int      @default(0)
  posturePercent          Int      @default(0)
  rmfProgressPercent      Int      @default(0)
  evidenceCompletePercent Int      @default(0)
  openPoams               Int      @default(0)
  overduePoams            Int      @default(0)
  openVulnCritical        Int      @default(0)
  openVulnHigh            Int      @default(0)
  openRisks               Int      @default(0)
  createdAt               DateTime @default(now())

  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@unique([systemId, day])
  @@index([orgId, day])
}

// ---------------------------------------------------------------------------
// Integrations (external connectors)
// ---------------------------------------------------------------------------

model Integration {
  id         String    @id @default(cuid())
  type       String // TENABLE | QUALYS | SERVICENOW | SHAREPOINT | EMASS
  name       String
  enabled    Boolean   @default(true)
  config     String    @default("{}") // JSON: { mock, baseUrl, accessKey, secretKey, ... } (encrypt at rest in prod)
  systemId   String? // default target system for scanner sync
  lastSyncAt DateTime?
  lastResult String    @default("")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

// ---------------------------------------------------------------------------
// Notifications (continuous-monitoring rule output)
// ---------------------------------------------------------------------------

model Notification {
  id         String   @id @default(cuid())
  orgId      String
  systemId   String?
  systemName String?
  category   String // POAM_OVERDUE | RMF_OVERDUE | VULN_OPEN | RISK_OPEN | RISK_ACCEPT_EXPIRING | EVIDENCE_MISSING
  severity   String   @default("WARNING") // INFO | WARNING | CRITICAL
  title      String
  body       String   @default("")
  dedupeKey  String // stable per underlying condition; lets re-runs upsert instead of duplicate
  entityType String?
  entityId   String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([orgId, dedupeKey])
  @@index([orgId, isRead])
}

// ---------------------------------------------------------------------------
// Audit log (append-only)
// ---------------------------------------------------------------------------

model AuditEvent {
  id         String   @id @default(cuid())
  action     String // e.g. "system.create", "poam.status_change"
  entityType String
  entityId   String?
  metadata   String? // JSON-encoded object
  createdAt  DateTime @default(now())

  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id])

  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Assessment & Authorization (Security Control Assessment → SAR → AO decision)
// ---------------------------------------------------------------------------

model Assessment {
  id           String    @id @default(cuid())
  title        String
  assessorName String    @default("")
  status       String    @default("DRAFT") // DRAFT | IN_PROGRESS | COMPLETED
  summary      String    @default("")
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  results ControlAssessmentResult[]

  @@index([systemId])
}

model ControlAssessmentResult {
  id             String   @id @default(cuid())
  controlId      String // 800-53 control id snapshot, e.g. "AC-2" (kept stable even if catalog changes)
  controlTitle   String   @default("")
  result         String   @default("NOT_ASSESSED") // SATISFIED | OTHER_THAN_SATISFIED | NOT_APPLICABLE | NOT_ASSESSED
  findings       String   @default("")
  recommendation String   @default("")
  updatedAt      DateTime @updatedAt

  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, controlId])
  @@index([assessmentId])
}

// CMMC / 800-171 asset inventory & CUI boundary scoping.
model Asset {
  id          String   @id @default(cuid())
  name        String
  assetType   String   @default("Other") // Server | Workstation | Network | Cloud Service | Application | Mobile | Other
  category    String   @default("OUT_OF_SCOPE") // CUI | SECURITY_PROTECTION | CONTRACTOR_RISK_MANAGED | SPECIALIZED | OUT_OF_SCOPE
  description String   @default("")
  owner       String   @default("")
  location    String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  systemId String
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@index([systemId])
}

// Assessor "request more evidence" workflow — read-only assessors flag a control needing more proof.
model EvidenceRequest {
  id         String    @id @default(cuid())
  controlId  String // control id snapshot, e.g. "AC-2" or "3.1.1"
  note       String    @default("") // what the assessor needs
  status     String    @default("OPEN") // OPEN | RESOLVED
  response   String    @default("") // the team's reply on resolution
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  systemId      String
  system        System  @relation(fields: [systemId], references: [id], onDelete: Cascade)
  requestedById String?
  requestedBy   User?   @relation("EvidenceRequester", fields: [requestedById], references: [id])

  @@index([systemId])
}

model AuthorizationDecision {
  id                  String    @id @default(cuid())
  decision            String // ATO | ATO_WITH_CONDITIONS | IATT | DENIED | REVOKED
  authorizingOfficial String
  decisionDate        DateTime  @default(now())
  expiresAt           DateTime?
  rationale           String    @default("")
  conditions          String    @default("")
  createdAt           DateTime  @default(now())

  systemId   String
  system     System  @relation(fields: [systemId], references: [id], onDelete: Cascade)
  signedById String?
  signedBy   User?   @relation("AuthorizationSigner", fields: [signedById], references: [id])

  @@index([systemId])
}
