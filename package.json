{
  "name": "lustrew-cyberstar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "screenshots": "node scripts/screenshots.mjs",
    "demo-gif": "node scripts/demo-gif.mjs",
    "db:provider:sqlite": "tsx scripts/set-db-provider.ts sqlite",
    "db:provider:postgres": "tsx scripts/set-db-provider.ts postgresql",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:migrate": "prisma migrate deploy",
    "db:import-oscal": "tsx scripts/import-oscal.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.9.3",
    "otplib": "^12.0.1",
    "next": "^15.1.3",
    "pdfkit": "^0.15.2",
    "next-auth": "^4.24.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@playwright/test": "^1.49.1",
    "@types/pdfkit": "^0.13.9",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.3",
    "gifenc": "^1.0.3",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.49",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
