# --- Database ---
# Local dev uses SQLite (zero setup). The file is created on `npm run db:push`.
DATABASE_URL="file:./dev.db"
# For production Postgres instead, set provider="postgresql" in prisma/schema.prisma and use:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/cyberstar?schema=public"

# --- NextAuth ---
# Generate a secret with:  openssl rand -base64 32   (or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# --- AI assistant (optional) ---
# Without a key, AI drafting returns a clearly-marked templated stub instead of calling Claude.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"

# --- Mail (invites & password resets) ---
# "console" logs emails to the server console + an in-memory outbox (local/dev). Implement an
# SMTP/SES driver in src/lib/mailer.ts and switch this for production delivery.
MAILER_DRIVER="console"

# --- File storage (evidence uploads) ---
STORAGE_DRIVER="local"
STORAGE_DIR=".data/uploads"

# --- Secrets encryption (integration credentials at rest) ---
# 32+ char random string. If unset, a key is derived from NEXTAUTH_SECRET (fine for dev).
# Set a dedicated key in production:  openssl rand -base64 32
ENCRYPTION_KEY=""

# --- Notifications scheduler ---
# Set a secret, then have cron POST to /api/notifications/run with header `x-cron-secret: <value>`
# to recompute continuous-monitoring alerts for all orgs (no session needed).
CRON_SECRET=""
